{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.AspNetCore.Diagnostics.ExceptionHandlerMiddleware": "None",
      "BDDSupercharged": "Debug"
    },
    "Console": {
      "FormatterName": "simple",
      "FormatterOptions": {
        "SingleLine": true,
        "IncludeScopes": true,
        "TimestampFormat": "HH:mm:ss ",
        "UseUtcTimestamp": true
      }
    }
  },
  "AllowedHosts": "*",
  "BDDSupercharged": {
    "Conversation": {
      "DefaultMaxRounds": 5,
      "ConsensusThreshold": 0.8,
      "RoundTimeoutSeconds": 30
    },
    "Translation": {
      "DefaultTechStack": "dotnet",
      "DefaultTestFramework": "xunit",
      "SupportedStacks": [ "dotnet", "javascript", "python", "java" ],
      "QualityTargets": {
        "MinCoverage": 0.8,
        "MaxComplexity": 10
      }
    },
    "Evolution": {
      "DefaultStrategy": "preserve-intent",
      "MaxBreakingChanges": 10,
      "PreservationThreshold": 0.7
    },
    "DriftDetection": {
      "DefaultMethods": [ "semantic", "structural", "behavioral" ],
      "DefaultSensitivity": 0.7,
      "SeverityThresholds": {
        "High": 0.8,
        "Medium": 0.5,
        "Low": 0.3
      }
    },
    "Documentation": {
      "DefaultFormat": "html",
      "SupportedFormats": [ "html", "markdown", "json" ],
      "DefaultAudience": "developer",
      "InteractiveFeaturesEnabled": true
    },
    "RateLimiting": {
      "Enabled": true,
      "MaxRequestsPerMinute": 60,
      "BurstLimit": 10
    }
  },
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://localhost:5000"
      },
      "Https": {
        "Url": "https://localhost:5001"
      }
    }
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/bdd-supercharged-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 7,
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {SourceContext} {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ]
  }
}