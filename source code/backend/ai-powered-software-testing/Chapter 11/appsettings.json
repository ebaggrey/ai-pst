{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning",
      "FullSpectrumApp": "Information"
    },
    "Console": {
      "LogLevel": {
        "Default": "Information",
        "FullSpectrumApp.Orchestrators": "Debug",
        "FullSpectrumApp.Services": "Debug"
      }
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Server=(localdb)\\mssqllocaldb;Database=FullSpectrumDb;Trusted_Connection=True;MultipleActiveResultSets=true;TrustServerCertificate=true"
  },
  "LLM": {
    "Provider": "OpenAI",
    "BaseUrl": "https://api.openai.com/v1/",
    "ApiKey": "your-api-key-here",
    "Model": "gpt-4",
    "MaxTokens": 2000,
    "Temperature": 0.7
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000",
      "https://localhost:3000",
      "http://localhost:5000",
      "https://localhost:5001"
    ]
  },
  "Database": {
    "CommandTimeout": 30,
    "EnableSensitiveDataLogging": false,
    "EnableDetailedErrors": false,
    "MaxRetryCount": 5,
    "MaxRetryDelaySeconds": 30
  },
  "Services": {
    "DatabaseService": {
      "CacheDurationMinutes": 10
    },
    "LLMService": {
      "RetryCount": 3,
      "RetryDelayMilliseconds": 1000
    }
  },
  "Orchestrators": {
    "ShiftLeftOrchestrator": {
      "MaxRequirementsPerBatch": 50,
      "EnableCaching": true
    },
    "TestabilityAnalyzer": {
      "MaxFileSizeKB": 1024,
      "AnalysisTimeoutSeconds": 60
    },
    "ShiftRightOrchestrator": {
      "MaxMonitorsPerRequest": 20,
      "EnableRealTimeMonitoring": true
    },
    "SpectrumPipelineBuilder": {
      "MaxStages": 10,
      "ValidateDependencies": true
    },
    "CrossSpectrumOrchestrator": {
      "MaxParallelTests": 10,
      "DefaultTimeoutMinutes": 30
    }
  },
  "Performance": {
    "EnableResponseCompression": true,
    "EnableResponseCaching": true,
    "ResponseCacheDurationSeconds": 60
  },
  "Security": {
    "RequireHttps": true,
    "EnableCsrfProtection": false
  },
  "AllowedHosts": "*"
}