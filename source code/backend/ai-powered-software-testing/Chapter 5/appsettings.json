{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning",
      "TDDReimagined": "Information",
      "TDDReimagined.API": "Debug"
    },
    "Console": {
      "LogLevel": {
        "Default": "Information",
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information"
      },
      "FormatterOptions": {
        "SingleLine": true,
        "TimestampFormat": "HH:mm:ss ",
        "UseUtcTimestamp": true
      }
    },
    "Debug": {
      "LogLevel": {
        "Default": "Debug"
      }
    }
  },
  "TDD": {
    "MaxTestComplexity": 15,
    "DefaultImplementationStrategy": "simplest-first",
    "AllowedTddStyles": [ "classic", "outside-in", "inside-out", "london", "chicago" ],
    "DefaultTimeHorizon": "quarterly",
    "MinTestCountForRefactoring": 3,
    "EnableFuturePredictions": true,
    "ComplexityThresholds": {
      "Low": 5,
      "Medium": 10,
      "High": 20
    },
    "QualityMetrics": {
      "MinConfidenceScore": 0.6,
      "MaxCyclomaticComplexity": 15,
      "TargetMaintainabilityIndex": 0.7
    },
    "Refactoring": {
      "MaxStepsWithoutCheckpoint": 5,
      "EnableSafetyChecks": true,
      "DefaultRollbackStrategy": "last-successful",
      "SuccessRate": 0.95
    },
    "EnableDetailedLogging": true,
    "EnableVirtualTestExecution": true,
    "SimulateAsyncDelays": true,
    "DelayMilliseconds": 100,
    "MaxGeneratedTests": 10,
    "MaxImplementationOptions": 5,
    "DefaultConfidenceThreshold": 0.7
  },
  "AllowedHosts": "*",
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://localhost:5000"
      },
      "Https": {
        "Url": "https://localhost:5001"
      }
    },
    "Limits": {
      "MaxRequestBodySize": 52428800,
      "MaxConcurrentConnections": 100,
      "MaxConcurrentUpgradedConnections": 100
    }
  },
  "Application": {
    "Name": "TDD Reimagined API",
    "Version": "1.0.0",
    "Environment": "Development",
    "EnableSwagger": true,
    "ApiTitle": "TDD Reimagined API",
    "ApiDescription": "A comprehensive API for TDD workflows",
    "ApiContactName": "Development Team",
    "ApiContactEmail": "dev@tddreimagined.com"
  },
  "Cors": {
    "AllowedOrigins": [ "http://localhost:3000", "http://localhost:8080", "https://tddreimagined.com" ],
    "AllowedMethods": [ "GET", "POST", "PUT", "DELETE", "OPTIONS" ],
    "AllowedHeaders": [ "*" ],
    "AllowCredentials": true
  }
}