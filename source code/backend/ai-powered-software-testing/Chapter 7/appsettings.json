{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning",
      "PipelineCookbook": "Debug"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ],
    "Properties": {
      "Application": "PipelineCookbook"
    }
  },
  "LLM": {
    "Provider": "OpenAI",
    "BaseUrl": "https://api.openai.com/v1/",
    "ApiKey": "your-openai-api-key-here",
    "Model": "gpt-4-turbo-preview",
    "SystemPrompt": "You are an expert DevOps engineer specializing in CI/CD pipeline optimization and automation. Provide detailed, actionable responses in JSON format.",
    "Temperature": 0.7,
    "MaxTokens": 2000
  },
  "ConnectionStrings": {
    "PipelineDatabase": "Server=(localdb)\\mssqllocaldb;Database=PipelineCookbookDb;Trusted_Connection=True;MultipleActiveResultSets=true",
    "RedisCache": "localhost:6379"
  },
  "PipelineSettings": {
    "MaxStagesPerPipeline": 20,
    "DefaultTimeoutMinutes": 30,
    "EnableTelemetry": true,
    "RetryCount": 3,
    "RetryDelaySeconds": 5
  },
  "AllowedHosts": "*"
}
