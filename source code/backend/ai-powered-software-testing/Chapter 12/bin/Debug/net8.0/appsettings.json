{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning",
      "System.Net.Http.HttpClient": "Warning"
    },
    "Console": {
      "LogLevel": {
        "Default": "Information",
        "Microsoft.AspNetCore": "Warning"
      }
    }
  },
  "AllowedHosts": "*",
  "AIService": {
    "BaseUrl": "https://api.openai.com",
    "ApiKey": "your-api-key-here",
    "ModelName": "gpt-4",
    "TimeoutSeconds": 30,
    "MaxRetries": 3,
    "DefaultParameters": {
      "temperature": 0.7,
      "top_p": 0.9,
      "frequency_penalty": 0,
      "presence_penalty": 0
    }
  },
  "Database": {
    "ConnectionString": "Server=(localdb)\\mssqllocaldb;Database=AIPoweredTestingDB;Trusted_Connection=True;MultipleActiveResultSets=true;TrustServerCertificate=True",
    "CommandTimeout": 30,
    "EnableSensitiveDataLogging": false
  },
  "Cors": {
    "AllowedOrigins": [
      "https://localhost:3000",
      "https://localhost:5000",
      "http://localhost:3000",
      "http://localhost:5000"
    ]
  },
  "RateLimiting": {
    "EnableRateLimiting": true,
    "PermitLimit": 100,
    "WindowSeconds": 60
  },
  "Cache": {
    "ResponseCacheDurationSeconds": 60
  }
}