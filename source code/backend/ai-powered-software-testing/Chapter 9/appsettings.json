{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/leantesting-.txt",
          "rollingInterval": "Day",
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level}] {Message}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ]
  },
  "LeanTesting": {
    "MaxFeaturesPerBatch": 50,
    "DefaultConfidenceTarget": 0.8,
    "ParetoThreshold": 0.8,
    "MinROIThreshold": 1.5,
    "MaxTestCasesPerFeature": 20,
    "EnableCaching": true,
    "CacheDurationMinutes": 60,
    "Features": {
      "PrioritizationEnabled": true,
      "CoverageGenerationEnabled": true,
      "AutomationDecisionEnabled": true,
      "MaintenanceOptimizationEnabled": true,
      "ROIMeasurementEnabled": true
    },
    "Validation": {
      "StrictMode": true,
      "ValidateConstraints": true,
      "EnforceLeanPrinciples": true
    }
  },
  "LLM": {
    "BaseUrl": "http://localhost:11434", // Ollama default
    "ModelName": "llama2",
    "ApiKey": "", // If using OpenAI or other services
    "TimeoutSeconds": 30,
    "MaxTokens": 2048,
    "Temperature": 0.7,
    "Enabled": true,
    "Provider": "Ollama", // Options: Ollama, OpenAI, AzureOpenAI, Custom
    "Endpoints": {
      "GenerateScenarios": "/api/generate/scenarios",
      "OptimizeTests": "/api/generate/optimize",
      "ExplainReasoning": "/api/generate/explain"
    }
  },
  "AllowedHosts": "*",
  "Cors": {
    "AllowedOrigins": [ "http://localhost:3000", "https://localhost:5001" ]
  },
  "Cache": {
    "DefaultExpirationMinutes": 30,
    "RedisConnectionString": "" // Optional: for distributed cache
  },
  "Metrics": {
    "Enabled": true,
    "PrometheusEndpoint": "/metrics"
  }
}