{
  "ConnectionStrings": {
    "DefaultConnection": "Server=(localdb)\\mssqllocaldb;Database=MetricsThatMatterDb;Trusted_Connection=True;MultipleActiveResultSets=true"
  },
  "LLM": {
    "BaseUrl": "http://localhost:5000",
    "ApiKey": "your-llm-api-key",
    "Model": "gpt-4",
    "MaxTokens": 2000,
    "Temperature": 0.7
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning",
      "MetricsThatMatter": "Debug"
    },
    "Console": {
      "LogLevel": {
        "Default": "Information",
        "MetricsThatMatter": "Debug"
      }
    }
  },
  "AllowedHosts": "*",
  "ApplicationInsights": {
    "Enabled": false,
    "ConnectionString": ""
  },
  "Cors": {
    "AllowedOrigins": [
      "https://localhost:3000",
      "https://localhost:5000",
      "https://metricsthatmatter.com"
    ],
    "AllowedMethods": [
      "GET",
      "POST",
      "PUT",
      "DELETE",
      "OPTIONS"
    ],
    "AllowedHeaders": [
      "Content-Type",
      "Authorization",
      "X-Requested-With"
    ]
  },
  "MetricsThatMatter": {
    "ApiVersion": "1.0",
    "MaxMetricsPerDesign": 10,
    "DefaultConfidenceThreshold": 0.8,
    "MinimumHistoricalDataPoints": 30,
    "PredictionHorizonMax": 90,
    "InsightActionabilityThreshold": 0.7,
    "EnableDetailedLogging": true
  },
  "Analysis": {
    "NormalizationMethods": {
      "Default": "z-score",
      "Available": [ "min-max", "z-score", "decimal-scaling" ]
    },
    "WeightingStrategies": {
      "Default": "equal",
      "Available": [ "equal", "custom", "statistical", "business-value" ]
    },
    "PatternDetection": {
      "MinimumDataPoints": 30,
      "SeasonalityDetection": true,
      "TrendDetection": true,
      "AnomalySensitivity": 2.0
    }
  },
  "Prediction": {
    "Models": {
      "Default": "arima",
      "Available": [ "arima", "exponential-smoothing", "linear-regression", "prophet" ]
    },
    "ConfidenceLevels": [ 0.8, 0.9, 0.95, 0.99 ],
    "MaxPredictionHorizon": 365,
    "RequireHistoricalData": true
  },
  "Optimization": {
    "Goals": {
      "Available": [ "cost-reduction", "efficiency", "quality", "coverage" ]
    },
    "MaxOptimizationIterations": 10,
    "PreserveCriticalMetrics": true
  },
  "Cache": {
    "Enabled": true,
    "DurationSeconds": 300,
    "PredictionCacheDuration": 600
  },

  "$schema": "https://json.schemastore.org/launchsettings.json",
  "profiles": {
    "http": {
      "commandName": "Project",
      "dotnetRunMessages": true,
      "launchBrowser": true,
      "launchUrl": "swagger",
      "applicationUrl": "http://localhost:5000",
      "environmentVariables": {
        "ASPNETCORE_ENVIRONMENT": "Development"
      }
    },
    "https": {
      "commandName": "Project",
      "dotnetRunMessages": true,
      "launchBrowser": true,
      "launchUrl": "swagger",
      "applicationUrl": "https://localhost:7066;http://localhost:5000",
      "environmentVariables": {
        "ASPNETCORE_ENVIRONMENT": "Development"
      }
    }
  }


}