{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.AspNetCore.SignalR": "Information",
      "Microsoft.AspNetCore.Http.Connections": "Information"
    }
  },
  "AllowedHosts": "*",
  "HumanLoop": {
    "ConfidenceThresholds": {
      "AutoApprove": 0.92,
      "LightReview": 0.75,
      "FullReview": 0.60,
      "HumanRequired": 0.40
    },
    "ReviewGuidance": {
      "AlwaysReview": [
        "security-tests",
        "payment-flows",
        "data-migration"
      ],
      "QuickReview": [
        "ui-component-tests",
        "api-contract-tests",
        "utility-functions"
      ],
      "SampleReview": [
        "generated-bulk-tests",
        "similar-pattern-tests"
      ]
    },
    "CollaborationDefaults": {
      "MaxActiveSessionsPerUser": 5,
      "SessionTimeoutMinutes": 120,
      "AutoSaveIntervalSeconds": 30,
      "MaxUndoSteps": 50,
      "CollaboratorLimit": 5
    },
    "LearningSettings": {
      "StoreAllJudgments": true,
      "MinimumSamplesForRetraining": 100,
      "RetrainingSchedule": "weekly",
      "FeedbackImpactWeight": 0.7,
      "HumanOverridePriority": "high"
    }
  },
  "Collaboration": {
    "Tools": {
      "DiffView": {
        "Enabled": true,
        "SideBySide": true,
        "HighlightChanges": true,
        "WordLevelDiff": false
      },
      "Suggestions": {
        "Enabled": true,
        "Frequency": "on-edit",
        "MaxSuggestions": 3,
        "AutoApply": false
      },
      "Chat": {
        "Enabled": true,
        "Persistent": true,
        "Threaded": true
      }
    }
  },
  "LearningFromJudgments": {
    "EnableAutomaticLearning": true,
    "BatchSizeForTraining": 50,
    "PrioritizedCategories": [
      "security",
      "business_logic",
      "edge_cases"
    ],
    "MinimumConfidenceForLearning": 0.7
  },
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://localhost:5000"
      },
      "Https": {
        "Url": "https://localhost:5001"
      }
    }
  }
}